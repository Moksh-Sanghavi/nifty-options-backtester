# ──────────────────────────────────────────────────────────────────────────
#  Copy to `.env` and adjust as needed:  cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────

# Redis broker + Celery result backend
REDIS_URL=redis://redis:6379/0

# Where the backend reads .parquet datasets from (inside the container)
DATA_DIR=/app/data

# Base URL the browser uses to reach the API (read by the Next.js frontend)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
